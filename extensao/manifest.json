{
  "manifest_version": 3,
  "name": "Gerador CPF/RG",
  "version": "1.0",
  "description": "Gera CPF, RG, CNPJ e Inscrição Estadual (formato válido) para uso em testes.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["gerador.js", "configuracao.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "gerador-cpf-rg@andrelmi"
    }
  }
}
